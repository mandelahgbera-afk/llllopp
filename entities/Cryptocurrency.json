{
  "name": "Cryptocurrency",
  "type": "object",
  "properties": {
    "symbol": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "price": {
      "type": "number",
      "default": 0
    },
    "change_24h": {
      "type": "number",
      "default": 0
    },
    "market_cap": {
      "type": "number",
      "default": 0
    },
    "volume_24h": {
      "type": "number",
      "default": 0
    },
    "icon_color": {
      "type": "string",
      "default": "#F7931A"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "symbol",
    "name",
    "price"
  ]
}