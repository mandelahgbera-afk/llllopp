{
  "name": "Transaction",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "deposit",
        "withdrawal",
        "buy",
        "sell",
        "copy_profit"
      ]
    },
    "amount": {
      "type": "number"
    },
    "crypto_symbol": {
      "type": "string"
    },
    "crypto_amount": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected",
        "completed"
      ],
      "default": "pending"
    },
    "notes": {
      "type": "string"
    },
    "wallet_address": {
      "type": "string"
    }
  },
  "required": [
    "user_email",
    "type",
    "amount"
  ]
}